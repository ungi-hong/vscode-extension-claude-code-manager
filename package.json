{
  "name": "claude-code-manager",
  "displayName": "Claude Code Manager",
  "description": "VSCode/Cursor 拡張内で Claude Code セッションを起動・対話できるダッシュボード。フォルダ単位でセッションを管理し、Webview チャットで完結",
  "version": "0.1.0",
  "publisher": "hong-woongi-ab",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ccmgr",
          "title": "Claude Code Manager",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ccmgr": [
        {
          "id": "ccmgr.sessions",
          "name": "Sessions",
          "icon": "media/icon.svg",
          "contextualTitle": "Claude Code Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeCodeManager.openSession",
        "title": "Open Session Detail",
        "category": "Claude Code Manager",
        "icon": "$(open-preview)"
      },
      {
        "command": "claudeCodeManager.refresh",
        "title": "Refresh Sessions",
        "category": "Claude Code Manager",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeCodeManager.copySessionId",
        "title": "Copy Session ID",
        "category": "Claude Code Manager"
      },
      {
        "command": "claudeCodeManager.hideSession",
        "title": "Hide from Sidebar",
        "category": "Claude Code Manager",
        "icon": "$(eye-closed)"
      },
      {
        "command": "claudeCodeManager.showHiddenSessions",
        "title": "Show Hidden Sessions...",
        "category": "Claude Code Manager",
        "icon": "$(eye)"
      },
      {
        "command": "claudeCodeManager.removeSession",
        "title": "Remove from Sidebar (Permanent)...",
        "category": "Claude Code Manager",
        "icon": "$(trash)"
      },
      {
        "command": "claudeCodeManager.showForgottenSessions",
        "title": "Show Removed Sessions...",
        "category": "Claude Code Manager",
        "icon": "$(history)"
      },
      {
        "command": "claudeCodeManager.focusSidebar",
        "title": "Focus Claude Code Manager Sidebar",
        "category": "Claude Code Manager"
      },
      {
        "command": "claudeCodeManager.addFolder",
        "title": "Add Folder...",
        "category": "Claude Code Manager",
        "icon": "$(new-folder)"
      },
      {
        "command": "claudeCodeManager.removeFolder",
        "title": "Remove Folder",
        "category": "Claude Code Manager",
        "icon": "$(trash)"
      },
      {
        "command": "claudeCodeManager.newSession",
        "title": "New Session",
        "category": "Claude Code Manager",
        "icon": "$(plus)"
      },
      {
        "command": "claudeCodeManager.forgetSession",
        "title": "Forget Managed Session",
        "category": "Claude Code Manager",
        "icon": "$(trash)"
      },
      {
        "command": "claudeCodeManager.stopSession",
        "title": "Stop Generating",
        "category": "Claude Code Manager",
        "icon": "$(stop-circle)"
      },
      {
        "command": "claudeCodeManager.showLogs",
        "title": "Show Output Logs",
        "category": "Claude Code Manager",
        "icon": "$(output)"
      },
      {
        "command": "claudeCodeManager.renameSession",
        "title": "題名の変更",
        "category": "Claude Code Manager",
        "icon": "$(edit)"
      },
      {
        "command": "claudeCodeManager.resetSessionTitle",
        "title": "題名を自動生成に戻す",
        "category": "Claude Code Manager",
        "icon": "$(discard)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeCodeManager.addFolder",
          "when": "view == ccmgr.sessions",
          "group": "navigation@1"
        },
        {
          "command": "claudeCodeManager.refresh",
          "when": "view == ccmgr.sessions",
          "group": "navigation@2"
        },
        {
          "command": "claudeCodeManager.showHiddenSessions",
          "when": "view == ccmgr.sessions",
          "group": "navigation@3"
        },
        {
          "command": "claudeCodeManager.showForgottenSessions",
          "when": "view == ccmgr.sessions",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeCodeManager.newSession",
          "when": "view == ccmgr.sessions && viewItem =~ /^folder\\./",
          "group": "inline@1"
        },
        {
          "command": "claudeCodeManager.removeFolder",
          "when": "view == ccmgr.sessions && viewItem == folder.user",
          "group": "9_remove"
        },
        {
          "command": "claudeCodeManager.openSession",
          "when": "view == ccmgr.sessions && viewItem =~ /^session\\./",
          "group": "inline@1"
        },
        {
          "command": "claudeCodeManager.stopSession",
          "when": "view == ccmgr.sessions && viewItem == session.managed",
          "group": "inline@2"
        },
        {
          "command": "claudeCodeManager.renameSession",
          "when": "view == ccmgr.sessions && viewItem =~ /^session\\./",
          "group": "1_rename@1"
        },
        {
          "command": "claudeCodeManager.resetSessionTitle",
          "when": "view == ccmgr.sessions && viewItem =~ /^session\\./",
          "group": "1_rename@2"
        },
        {
          "command": "claudeCodeManager.hideSession",
          "when": "view == ccmgr.sessions && viewItem =~ /^session\\./",
          "group": "8_archive@1"
        },
        {
          "command": "claudeCodeManager.removeSession",
          "when": "view == ccmgr.sessions && viewItem =~ /^session\\./",
          "group": "8_archive@2"
        },
        {
          "command": "claudeCodeManager.copySessionId",
          "when": "view == ccmgr.sessions && viewItem =~ /^session\\./",
          "group": "9_copy"
        },
        {
          "command": "claudeCodeManager.forgetSession",
          "when": "view == ccmgr.sessions && viewItem == session.managed",
          "group": "9_forget"
        }
      ]
    },
    "configuration": {
      "title": "Claude Code Manager",
      "properties": {
        "claudeCodeManager.staleAfterMinutes": {
          "type": "number",
          "default": 30,
          "description": "セッションが何分間更新されないと stale として薄表示にするか"
        },
        "claudeCodeManager.hideSessionsOlderThanHours": {
          "type": "number",
          "default": 24,
          "description": "起動時に何時間以上前のセッションを初期ロード対象から除外するか"
        },
        "claudeCodeManager.maxEventsPerSession": {
          "type": "number",
          "default": 200,
          "description": "registry が保持する 1 セッションあたりの直近イベント数 (Webview で全件必要なら都度 jsonl から再ロード)"
        },
        "claudeCodeManager.claudePath": {
          "type": "string",
          "default": "",
          "description": "`claude` CLI バイナリの絶対パス。空の場合は PATH から `which claude` で自動検出。それもダメなら SDK 同梱のバイナリ (~208MB) を使う。"
        },
        "claudeCodeManager.defaultPermissionMode": {
          "type": "string",
          "enum": ["default", "plan", "acceptEdits", "bypassPermissions"],
          "enumDescriptions": [
            "通常モード (毎回確認)",
            "Plan モード (読み取り専用、変更案の提示のみ)",
            "Auto-accept edits (ファイル編集を自動承認)",
            "--dangerously-skip-permissions 相当 (全権限スキップ・自己責任)"
          ],
          "default": "default",
          "description": "新規セッション起動時のデフォルト権限モード。Webview 入力欄にフォーカスして Shift+Tab で実行中にもサイクル切替できる"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "vscode:prepublish": "npm run build",
    "package": "vsce package --no-dependencies --allow-missing-repository --baseContentUrl https://example.local --baseImagesUrl https://example.local",
    "compile-tests": "tsc -p .",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.132",
    "chokidar": "^3.6.0",
    "dompurify": "^3.4.2",
    "marked": "^12.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.27.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
